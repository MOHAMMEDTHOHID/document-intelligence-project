# Document Intelligence Platform - Environment Variables

# OpenAI API Configuration
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# JWT Secret Key (Change this to a secure random string in production)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database Configuration (SQLite for development)
DATABASE_URL=sqlite:///./docs_intelligence.db

# Application Environment
DEBUG=True

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Frontend Configuration
FRONTEND_PORT=8501

# File Upload Configuration
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_EXTENSIONS=pdf,docx,txt

# AI Configuration
MODEL_NAME=gpt-3.5-turbo
MAX_TOKENS=2000
TEMPERATURE=0.7

# Feature Flags
ENABLE_EMAIL_GENERATION=True
ENABLE_QA_FEATURE=True
ENABLE_EMBEDDINGS=False
